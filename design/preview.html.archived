                      </select>
                    </div>
                    <div class="input-group">
                      <label class="input-label">Provider <span style="color:var(--color-status-error)">*</span></label>
                      <select class="input" style="cursor:pointer">
                        <option value="">Select provider…</option>
                        <option value="FREE" selected>Free</option>
                        <option value="ORANGE">Orange</option>
                        <option value="BOUYGUES">Bouygues</option>
                        <option value="SFR">SFR</option>
                        <option value="CORIOLIS">Coriolis</option>
                      </select>
                    </div>
                  </div>
                  <div class="input-group">
                    <label class="input-label">Mobile number <span style="color:var(--color-status-error)">*</span></label>
                    <div class="input-wrap"><input class="input" type="tel" value="07 98 76 54 32" style="font-family:var(--font-family-mono)" /></div>
                    <div class="helper-text">French mobile number (06 / 07 prefix)</div>
                  </div>
                  <!-- base_monthly_fee field intentionally hidden for prepaid — 0 sent automatically -->
                  <div class="input-group" style="padding:var(--space-3);background:var(--color-background-tertiary);border-radius:var(--radius-md)">
                    <div style="font-size:var(--font-size-xs);color:var(--color-text-secondary);display:flex;align-items:center;gap:var(--space-2)">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                      Prepaid SIMs have no monthly fee. €0.00 will be recorded automatically.
                    </div>
                  </div>
                  <div class="input-group">
                    <label class="input-label">Assign to phone <span style="color:var(--color-text-disabled);font-weight:var(--font-weight-regular)">(optional)</span></label>
                    <select class="input" style="cursor:pointer">
                      <option value="">Not assigned</option>
                      <option>iPhone 15 Pro</option>
                      <option>Google Pixel 8</option>
                    </select>
                  </div>
                </div>
                <div class="modal-footer">
                  <button class="btn btn-ghost">Cancel</button>
                  <button class="btn btn-primary">Add SIM Card</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Plan-02p: Phones SIM column ──────────────────────── -->
    <section class="section" id="plan02p-phones-sim">
      <div class="section-title">CustomerPhonesTab — enriched SIM column <span style="font-size:var(--font-size-sm);font-weight:var(--font-weight-regular);color:var(--color-text-secondary);margin-left:var(--space-2)">Plan-02p</span></div>
      <div class="section-desc">SIM card column now shows: <code>Provider · Number · type</code> and <code>· €X.XX/mo</code> appended for postpaid only. Rows with an assigned SIM show an "Unassign SIM" button alongside "Edit".</div>

      <div class="subsection">
        <div class="subsection-title">Populated — admin view</div>
        <div class="mini-table-wrap" data-comp="CustomerPhonesTab (enriched SIM column)">
          <table class="mini-table">
            <thead>
              <tr>
                <th>Model</th>
                <th>Ownership</th>
                <th>SIM Card</th>
                <th>Status</th>
                <th>Flags</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><span class="link">iPhone 15 Pro</span></td>
                <td class="muted">Company</td>
                <td>
                  <span style="font-family:var(--font-family-mono);font-size:12px;color:var(--color-text-primary)">Orange · +33 6 12 34 56 78</span>
                  <span class="muted" style="font-size:12px"> · postpaid · </span>
                  <span style="font-family:var(--font-family-mono);font-size:12px;color:var(--color-text-primary)">€89.00/mo</span>
                </td>
                <td><span class="mbadge mbadge-success">Active</span></td>
                <td>—</td>
                <td style="white-space:nowrap">
                  <button class="mini-btn mini-btn-danger" style="padding:4px 10px;font-size:12px;margin-right:4px">Unassign SIM</button>
                  <button class="mini-btn mini-btn-ghost" style="padding:4px 10px;font-size:12px">Edit</button>
                </td>
              </tr>
              <tr>
                <td><span class="link">Samsung Galaxy S24</span></td>
                <td class="muted">Customer</td>
                <td>
                  <span style="font-family:var(--font-family-mono);font-size:12px;color:var(--color-text-primary)">Free · +33 7 98 76 54 32</span>
                  <span class="muted" style="font-size:12px"> · prepaid</span>
                </td>
                <td><span class="mbadge mbadge-success">Active</span></td>
                <td>—</td>
                <td style="white-space:nowrap">
                  <button class="mini-btn mini-btn-danger" style="padding:4px 10px;font-size:12px;margin-right:4px">Unassign SIM</button>
                  <button class="mini-btn mini-btn-ghost" style="padding:4px 10px;font-size:12px">Edit</button>
                </td>
              </tr>
              <tr>
                <td><span class="link">iPhone 14</span></td>
                <td class="muted">Customer</td>
                <td class="muted">—</td>
                <td><span class="mbadge mbadge-warning">In Repair</span></td>
                <td><span class="mbadge mbadge-warning">No SIM</span></td>
                <td style="white-space:nowrap">
                  <button class="mini-btn mini-btn-secondary" style="padding:4px 10px;font-size:12px;margin-right:4px">Assign SIM</button>
                  <button class="mini-btn mini-btn-ghost" style="padding:4px 10px;font-size:12px">Edit</button>
                </td>
              </tr>
              <tr>
                <td><span class="link">Google Pixel 8</span></td>
                <td class="muted">Company</td>
                <td class="muted">—</td>
                <td><span class="mbadge mbadge-success">Active</span></td>
                <td><span class="mbadge mbadge-warning">No SIM</span></td>
                <td style="white-space:nowrap">
                  <button class="mini-btn mini-btn-secondary" style="padding:4px 10px;font-size:12px;margin-right:4px">Assign SIM</button>
                  <button class="mini-btn mini-btn-ghost" style="padding:4px 10px;font-size:12px">Edit</button>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="subsection">
        <div class="subsection-title">SIM column format reference</div>
        <div style="display:flex;flex-direction:column;gap:var(--space-3)">
          <div class="meta-row">
            <span class="meta-key">Postpaid with fee</span>
            <code class="meta-val" style="font-size:var(--font-size-xs);font-family:var(--font-family-mono)">Orange · +33 6 12 34 56 78 · postpaid · €89.00/mo</code>
          </div>
          <div class="meta-row">
            <span class="meta-key">Prepaid (no fee)</span>
            <code class="meta-val" style="font-size:var(--font-size-xs);font-family:var(--font-family-mono)">Free · +33 7 98 76 54 32 · prepaid</code>
          </div>
          <div class="meta-row">
            <span class="meta-key">No SIM assigned</span>
            <code class="meta-val" style="font-size:var(--font-size-xs);font-family:var(--font-family-mono)">—</code>
          </div>
        </div>
      </div>
    </section>

  </main>
</div>

<script>
  // ─── Theme toggle ────────────────────────────────────────────
  const html = document.documentElement;
  const themeToggle = document.getElementById('theme-toggle');
  const themeLabel  = document.getElementById('theme-label');

  themeToggle.addEventListener('click', () => {
    const isDark = html.getAttribute('data-theme') === 'dark';
    html.setAttribute('data-theme', isDark ? 'light' : 'dark');
    themeLabel.textContent = isDark ? 'Dark mode' : 'Light mode';
  });

  // ─── Font size toggle ────────────────────────────────────────
  const fontToggle = document.getElementById('font-toggle');
  const fontLabel  = document.getElementById('font-label');
  let large = false;

  fontToggle.addEventListener('click', () => {
    large = !large;
    html.classList.toggle('large-text', large);
    fontLabel.textContent = large ? 'Base text' : 'Large text';
  });

  // ─── Active sidebar link on scroll ───────────────────────────
  const sections = document.querySelectorAll('section[id]');
  const links    = document.querySelectorAll('.sidebar-link');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        links.forEach(l => l.classList.remove('active'));
        const active = document.querySelector(`.sidebar-link[href="#${entry.target.id}"]`);
        if (active) active.classList.add('active');
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });

  sections.forEach(s => observer.observe(s));

  // ─── Page state switcher ─────────────────────────────────────
  function pgState(pageKey, state, btn) {
    // update button styles
    const bar = btn.closest('.state-bar');
    bar.querySelectorAll('.state-btn').forEach(b => b.classList.remove('is-active'));
    btn.classList.add('is-active');

    // show/hide state panels for both mobile and desktop
    const section = btn.closest('.section');
    section.querySelectorAll('.ps').forEach(el => {
      const id = el.id;
      if (id.startsWith(pageKey + '-' + state)) {
        el.classList.add('visible');
      } else if (id.startsWith(pageKey + '-')) {
        el.classList.remove('visible');
      }
    });
  }
</script>
</body>
</html>
