    <!-- ─── Plan-02p: Updated Forms ─────────────────────────── -->
    <section class="section" id="plan02p-forms">
      <div class="section-title">Updated Forms <span style="font-size:var(--font-size-sm);font-weight:var(--font-weight-regular);color:var(--color-text-secondary);margin-left:var(--space-2)">Plan-02p</span></div>
      <div class="section-desc">CreateCustomerModal with optional contact fields. CreateSimCardModal with provider select, FR mobile number, and conditional fee field (hidden for prepaid).</div>

      <div class="subsection">
        <div class="subsection-title">CreateCustomerModal — contact info optional</div>
        <div class="modal-preview">
          <div class="modal-backdrop-mock">
            <div class="modal">
              <div class="modal-header">
                <div class="modal-title">New Customer</div>
                <button class="modal-close" aria-label="Close">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
              </div>
              <div class="modal-body">
                <div class="input-group">
                  <label class="input-label">Company name <span style="color:var(--color-status-error)">*</span></label>
                  <div class="input-wrap"><input class="input" type="text" placeholder="e.g. Al Barsha Trading LLC" /></div>
                  <div class="helper-text">Legal entity name as registered</div>
                </div>
                <div class="input-group">
                  <label class="input-label">Contact info <span style="color:var(--color-text-disabled);font-weight:var(--font-weight-regular)">(optional)</span></label>
                  <div class="input-wrap"><input class="input" type="text" placeholder="+971 50 123 4567 or email" /></div>
                  <div class="helper-text">Phone number, email, or other contact — can be added later</div>
                </div>
                <div class="input-group">
                  <label class="input-label">WhatsApp group ID <span style="color:var(--color-text-disabled);font-weight:var(--font-weight-regular)">(optional)</span></label>
                  <div class="input-wrap"><input class="input" type="text" placeholder="e.g. 120363012345678901@g.us" /></div>
                  <div class="helper-text">Required before WhatsApp notifications can be sent — can be added later</div>
                </div>
              </div>
              <div class="modal-footer">
                <button class="btn btn-ghost">Cancel</button>
                <button class="btn btn-primary">Create Customer</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-6)">
        <div class="subsection">
          <div class="subsection-title">CreateSimCardModal — postpaid (fee shown)</div>
          <div class="modal-preview" style="padding:var(--space-4)">
            <div class="modal-backdrop-mock" style="padding:var(--space-4)">
              <div class="modal">
                <div class="modal-header">
                  <div class="modal-title">Add SIM Card</div>
                  <button class="modal-close" aria-label="Close">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </button>
                </div>
                <div class="modal-body">
                  <div class="input-grid">
                    <div class="input-group">
                      <label class="input-label">Type <span style="color:var(--color-status-error)">*</span></label>
                      <select class="input" style="cursor:pointer">
                        <option value="postpaid" selected>Postpaid</option>
                        <option value="prepaid">Prepaid</option>
                      </select>
                    </div>
                    <div class="input-group">
                      <label class="input-label">Provider <span style="color:var(--color-status-error)">*</span></label>
                      <select class="input" style="cursor:pointer">
                        <option value="">Select provider…</option>
                        <option value="FREE">Free</option>
                        <option value="ORANGE" selected>Orange</option>
                        <option value="BOUYGUES">Bouygues</option>
                        <option value="SFR">SFR</option>
                        <option value="CORIOLIS">Coriolis</option>
                      </select>
