                  <div class="input-group">
                    <label class="input-label">Mobile number <span style="color:var(--color-status-error)">*</span></label>
                    <div class="input-wrap"><input class="input" type="tel" placeholder="06 or 07 — e.g. 06 12 34 56 78" style="font-family:var(--font-family-mono)" /></div>
                    <div class="helper-text">French mobile number (06 / 07 prefix)</div>
                  </div>
                  <div class="input-group">
                    <label class="input-label">Base monthly fee (€) <span style="color:var(--color-status-error)">*</span></label>
                    <div class="input-wrap"><input class="input" type="number" placeholder="0.00" style="font-family:var(--font-family-mono)" /></div>
                    <div class="helper-text">Fixed amount billed each month</div>
                  </div>
